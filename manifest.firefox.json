{
  "manifest_version": 2,
  "name": "Better Zeus",
  "author": "Axel Thauvin",
  "version": "1.0",
  "description": "Améliore l'interface de Zeus avec un calendrier juste plus beau.",
  "content_security_policy": "script-src 'self' object-src 'self'",
  "content_scripts": [
    {
      "matches": ["https://zeus.ionis-it.com/*"],
      "js": ["src/content/zeus-calendar.js"]
    }
  ],
  "icons": {
    "16": "src/icons/16x16.png",
    "48": "src/icons/48x48.png",
    "128": "src/icons/128x128.png"
  },
  "browser_specific_settings": {
    "gecko": { "id": "{97773fa8-059a-42d7-a3d0-edc929c3905f}" }
  },
  "license": "MIT"
}
