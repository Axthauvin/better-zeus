{
  "manifest_version": 3,
  "name": "Better Zeus",
  "author": "Axel Thauvin",
  "version": "1.0",
  "description": "Améliore l'interface de Zeus avec un calendrier juste plus beau.",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["https://zeus.ionis-it.com/*"],
      "js": ["src/content/zeus-calendar.js"]
    }
  ],
  "icons": {
    "16": "src/icons/16x16.png",
    "48": "src/icons/48x48.png",
    "128": "src/icons/128x128.png"
  }
}
